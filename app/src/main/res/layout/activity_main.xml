<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="La Ruta Más Corta"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Algoritmo de Dijkstra"
            android:textSize="13sp"
            android:textColor="#90A4AE"
            android:gravity="center"
            android:paddingBottom="28dp" />

        <!-- Card Origen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORIGEN"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:paddingBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerOrigen"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>

        <!-- Card Destino -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESTINO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#E53935"
                android:paddingBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerDestino"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>

        <!-- Botón Calcular -->
        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Calcular Ruta Más Corta"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- Card Resultado (oculto hasta calcular) -->
        <LinearLayout
            android:id="@+id/cardResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESULTADO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tvResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#263238"
                android:lineSpacingMultiplier="1.6"
                android:fontFamily="monospace" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>